{
  "project": "petclinic-mcp-bob",
  "projectPath": "legacy-to-mcp6/input-documents/petclinic-mcp-bob",
  "basePackage": "org.acme",
  "steps": [
    {
      "id": "step-1",
      "description": "Create DTO model classes for Pet, PetType, and Visit based on the OpenAPI spec",
      "files": [
        "src/main/java/org/acme/model/PetType.java",
        "src/main/java/org/acme/model/Visit.java",
        "src/main/java/org/acme/model/Pet.java"
      ]
    },
    {
      "id": "step-2",
      "description": "Create MicroProfile REST Client interface PetclinicService with GET endpoints for pets and petTypes",
      "files": [
        "src/main/java/org/acme/PetclinicService.java"
      ],
      "endpoints": [
        { "method": "GET", "path": "/api/pets", "operationId": "listPets", "returns": "List<Pet>" },
        { "method": "GET", "path": "/api/pets/{petId}", "operationId": "getPet", "returns": "Pet" },
        { "method": "GET", "path": "/api/pettypes", "operationId": "listPetTypes", "returns": "List<PetType>" }
      ]
    },
    {
      "id": "step-3",
      "description": "Create MCP Server tools class PetTools that exposes REST client operations as MCP tools",
      "files": [
        "src/main/java/org/acme/PetTools.java"
      ],
      "tools": [
        { "name": "listPets", "description": "List all pets from the Petclinic", "args": [] },
        { "name": "getPet", "description": "Get a pet by its ID", "args": [{ "name": "petId", "type": "int", "description": "The ID of the pet" }] },
        { "name": "listPetTypes", "description": "List all pet types", "args": [] }
      ]
    },
    {
      "id": "step-4",
      "description": "Configure application.properties with HTTP port 8888 and CORS enabled",
      "files": [
        "src/main/resources/application.properties"
      ]
    },
    {
      "id": "step-5",
      "description": "Update Kubernetes manifest to add MCP server as a sidecar container",
      "files": [
        "src/main/kubernetes/petclinic-kubernetes.yaml"
      ]
    }
  ],
  "constraints": {
    "onlyGetOperations": true,
    "doNotModifyLegacySource": true,
    "mcpPort": 8888,
    "petclinicPort": 9966,
    "sidecarImage": "petclinic-mcp-bob:1.0.0-SNAPSHOT"
  }
}
